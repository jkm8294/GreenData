# === GreenData MVP — Environment Variables ===

# Firecrawl (Reddit scraping)
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# EIA Open Data API v2 (electricity, generation, pricing)
EIA_API_KEY=your_eia_api_key_here

# NREL Developer API (solar irradiance, wind capacity)
NREL_API_KEY=your_nrel_api_key_here

# MongoDB Atlas (score storage)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/greendata

# Mapbox (frontend map)
MAPBOX_TOKEN=your_mapbox_token_here
